generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DefaultView {
  dashboard
  daily_notes
  agents
  complaints
  meetings
  agenda
  schedule
  reports
}

enum IncidentStatus {
  CRITICO
  EM_ANALISE
  RESOLVIDO
}

enum IncidentPriority {
  CRITICO
  NORMAL
}

enum IncidentRecordType {
  error
  complaint
}

enum IncidentVisualType {
  error
  warning
  success
}

enum IncidentHistoryAction {
  created
  assumed
  quick_resolved
  status_changed
  notes_changed
}

enum MeetingStatus {
  CONFIRMADA
  RASCUNHO
  REALIZADA
}

enum MeetingCategory {
  primary
  secondary
  tertiary
}

enum DailyNoteStatus {
  EM_ANALISE
  REALIZADO
}

enum DailyNoteCategory {
  ALTA_PRIORIDADE
  OPERACIONAL
  DOCUMENTACAO
}

enum DailyNoteDeadlinePreset {
  ONE_DAY
  ONE_WEEK
  CUSTOM
}

enum NotificationSource {
  meeting
  daily_note
}

enum NotificationKind {
  created
  updated
  completed
  deleted
  morning_alert
}

enum ReportModule {
  incidents
  meetings
  agents
}

enum ReportFormat {
  pdf
  excel
  csv
}

enum ReportExportStatus {
  CONCLUIDO
  FALHA
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  passwordHash  String
  fullName      String
  role          String
  profilePhoto  String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  settings      UserSettings?
  agents        Agent[]
  incidents     Incident[]
  meetings      Meeting[]
  dailyNotes    DailyNote[]
  notifications Notification[]
  reportExports ReportExport[]
  schedules     Schedule[]
}

model UserSettings {
  id                           String      @id @default(cuid())
  userId                       String      @unique
  defaultView                  DefaultView @default(dashboard)
  meetingsNotificationsEnabled Boolean     @default(true)
  createdAt                    DateTime    @default(now())
  updatedAt                    DateTime    @updatedAt
  user                         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Agent {
  id            String   @id @default(cuid())
  userId        String
  legacyId      Int?
  name          String
  role          String
  tenure        String?
  admissionDate DateTime? @db.Date
  trust         Int?
  rating        Int?
  behavior      String?
  photo         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, legacyId])
}

model Incident {
  id             String             @id @default(cuid())
  userId         String
  legacyId       Int?
  protocol       String?
  title          String
  description    String
  timeLabel      String?
  status         IncidentStatus
  priority       IncidentPriority
  reporter       String?
  agent          String?
  assumedBy      String?
  assumedAt      DateTime?
  treatmentNotes String?
  resolvedAt     DateTime?
  recordType     IncidentRecordType
  visualType     IncidentVisualType
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  history        IncidentHistory[]

  @@unique([userId, legacyId])
}

model IncidentHistory {
  id         String                @id @default(cuid())
  incidentId String
  action     IncidentHistoryAction
  details    String?
  occurredAt DateTime
  incident   Incident              @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model Meeting {
  id         String          @id @default(cuid())
  userId     String
  legacyId   Int?
  title      String
  date       DateTime        @db.Date
  time       String
  attendees  String
  location   String
  notes      String
  status     MeetingStatus
  category   MeetingCategory
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, legacyId])
}

model DailyNote {
  id             String                  @id @default(cuid())
  userId         String
  legacyId       Int?
  text           String
  date           DateTime                @db.Date
  status         DailyNoteStatus
  category       DailyNoteCategory?
  deadlinePreset DailyNoteDeadlinePreset?
  deadlineAt     DateTime?               @db.Date
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  completedAt    DateTime?
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, legacyId])
}

model Notification {
  id             String             @id @default(cuid())
  userId         String
  legacyId       String?
  source         NotificationSource
  kind           NotificationKind
  message        String
  meetingLegacyId Int?
  noteLegacyId   Int?
  meetingTitle   String?
  noteText       String?
  read           Boolean            @default(false)
  createdAt      DateTime
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, legacyId])
}

model ReportExport {
  id           String             @id @default(cuid())
  userId       String
  legacyId     String?
  fileName     String
  sizeLabel    String
  status       ReportExportStatus
  module       ReportModule
  format       ReportFormat
  startDate    String?
  endDate      String?
  fields       Json
  errorMessage String?
  createdAt    DateTime
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, legacyId])
}

model Schedule {
  id                 String   @id @default(cuid())
  userId             String
  referenceMonth     String
  selectedWeekendDate DateTime @db.Date
  records            Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, referenceMonth])
}
